# Copy to .env and fill in. .env is gitignored.

# --- Provider selection -------------------------------------------------------

# TTS backend. One of: cartesia | azure | openai | mai
# - cartesia : Sonic-3 + Skylar voice. Best naturalness. Needs CARTESIA_API_KEY.
# - azure    : Azure Speech (Ava Multilingual Neural). Needs AZURE_SPEECH_*.
# - openai   : gpt-4o-mini-tts via Azure AI Foundry. Needs AZURE_OPENAI_*.
# - mai      : Microsoft MAI-Voice-1 (preview). Uses AZURE_SPEECH_*.
TTS_PROVIDER=cartesia

# STT backend. One of: deepgram | azure | whisper
# - deepgram : Nova-3 with runtime keyterm biasing. Best on code-heavy speech
#              (file names, extensions, project-specific identifiers). Cloud.
# - azure    : Azure Speech with PhraseListGrammar (jargon biasing). Cloud.
# - whisper  : Local Whisper Large V3 Turbo Q4 (offline, MLX-accelerated).
STT_PROVIDER=deepgram

# --- Cartesia -----------------------------------------------------------------

CARTESIA_API_KEY=

# --- Deepgram (STT) -----------------------------------------------------------

DEEPGRAM_API_KEY=

# --- Azure Speech (STT + Azure/MAI TTS) ---------------------------------------

AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# Optional Azure TTS overrides (only used when TTS_PROVIDER=azure)
# AZURE_SPEECH_VOICE=en-US-AvaMultilingualNeural
# AZURE_SPEECH_PITCH=
# AZURE_SPEECH_RATE=

# Optional MAI-Voice-1 override (only used when TTS_PROVIDER=mai)
# MAI_VOICE=en-US-June:MAI-Voice-1

# --- Azure AI Foundry (OpenAI gpt-4o-mini-tts) --------------------------------

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-foundry-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-01-preview
AZURE_OPENAI_TTS_DEPLOYMENT=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=fable
